{
  "name": "im-code-map",
  "version": "5.3.0",
  "created_at": "2026-07-06",
  "updated_at": "2026-07-14",
  "description": "Human-first, evidence-grounded codebase understanding with Focus and Deep Atlas profiles, supporting both local CodeGraph analysis and immutable remote repository snapshots.",
  "status": "validated",
  "requires_preflight_gate": true,
  "mandatory_preflight": true,
  "default_profile": "focus",
  "supported_profiles": [
    "focus",
    "atlas"
  ],
  "default_policy": "QUESTION_SCOPED_PROGRESSIVE_DISCLOSURE_WITH_NO_SILENT_FALLBACK",
  "required_tools_for_normal_mode": [
    "python3"
  ],
  "default_documentation_provider": "agent-native-docs",
  "optional_documentation_providers": [
    "openwiki-cli"
  ],
  "optional_viewer_tools": [
    "obsidian",
    "obsidian-excalidraw-plugin",
    "excalidraw-automate"
  ],
  "atlas_escalation_triggers": [
    "authentication",
    "authorization",
    "payment",
    "privacy",
    "data-deletion",
    "migration",
    "concurrency",
    "idempotency",
    "retry-compensation",
    "cross-repository",
    "conflicting-evidence",
    "dynamic-dispatch",
    "broad-state-change",
    "user-request"
  ],
  "primary_outputs": [
    "understanding session and routing decision",
    "repository snapshot and acquisition integrity report",
    "coverage and explicit unknown boundaries",
    "shared evidence ledger and business stream model",
    "human overview and Focus Excalidraw flow",
    "Deep Atlas child diagrams and master composition",
    "SVG/PNG render-based visual QA previews",
    "question-centered Obsidian entry path",
    "detailed Atlas Obsidian graph and JSON Canvas",
    "package-owned Excalidraw stencil library and design tokens",
    "clean and whiteboard themed editable drawings"
  ],
  "commands": [
    "/im-code-map tools-check",
    "/im-code-map init",
    "/im-code-map snapshot-check",
    "/im-code-map orient",
    "/im-code-map trace",
    "/im-code-map explain",
    "/im-code-map before-change",
    "/im-code-map debug",
    "/im-code-map expand",
    "/im-code-map atlas",
    "/im-code-map validate",
    "/im-code-map after-change",
    "/im-code-map migrate-v4",
    "/im-code-map migrate-v3"
  ],
  "visual_themes": [
    "clean",
    "whiteboard"
  ],
  "default_visual_theme": "clean",
  "bundled_stencil_library": "libraries/im-code-map-architecture.excalidrawlib",
  "normal_evidence_modes": {
    "local-codegraph": {
      "required": [
        "git",
        "codegraph",
        "python3"
      ]
    },
    "remote-connector-snapshot": {
      "required": [
        "immutable-commit-ref",
        "repository-connector",
        "python3"
      ]
    },
    "hybrid": {
      "required": [
        "git-or-repository-connector",
        "immutable-commit-ref",
        "python3"
      ]
    }
  },
  "required_tools_for_local_codegraph_mode": [
    "git",
    "codegraph",
    "python3"
  ],
  "required_capabilities_for_remote_snapshot_mode": [
    "immutable-commit-ref",
    "repository-connector",
    "file-content-with-blob-sha",
    "python3"
  ]
}
