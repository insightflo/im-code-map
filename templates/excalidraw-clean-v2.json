{
  "version": "2.0",
  "name": "im-code-map clean v2",
  "canvas": {
    "background": "#fcfcfb",
    "grid": 20,
    "roughness": 0
  },
  "group": {
    "background": "#f7f8fa",
    "stroke": "#e5e7eb",
    "strokeWidth": 1,
    "opacity": 82,
    "radius": 18,
    "padding": 20,
    "headerHeight": 52,
    "nodeGap": 22
  },
  "node": {
    "width": 220,
    "baseHeight": 72,
    "background": "#ffffff",
    "stroke": "#d8dee7",
