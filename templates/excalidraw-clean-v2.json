  },
  "kindAccents": {
    "entry": "#64748b",
    "schedule": "#b7791f",
    "actor": "#c05621",
    "process": "#3b82f6",
    "decision": "#7c3aed",
    "service": "#2563eb",
    "store": "#059669",
    "external": "#0284c7",
    "outcome": "#16a34a",
    "risk": "#dc2626"
