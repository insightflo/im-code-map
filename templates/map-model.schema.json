      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "rule_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "failure_outcome": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "streamStep": {
