      "properties": {
        "kind": {
          "enum": [
            "user-intent",
            "api",
            "event",
            "schedule",
            "cli",
            "message",
            "system"
          ]
        },
        "source": {
          "type": "string"
        },
        "event": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "precondition": {
      "type": "object",
      "required": [
        "id",
        "description",
        "rule_refs",
        "failure_outcome"
