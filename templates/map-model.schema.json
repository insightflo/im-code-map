{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://im-code-map.local/schema/map-model-v5.json",
  "title": "im-code-map map-model v5",
  "type": "object",
  "required": [
    "schema_version",
    "workspace_id",
    "generated_at",
    "source_tools",
    "confidence",
    "tool_status",
    "documentation_provider",
    "profile_support",
    "codebases",
    "actors",
    "domains",
    "entities",
    "state_machines",
    "business_rules",
    "domain_interactions",
    "business_streams",
    "visual_outputs",
    "risks",
    "uncertainties"
  ],
  "properties": {
    "schema_version": {
      "const": "5.0.0"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "evidence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "enum": [
              "AVAILABLE",
              "MISSING",
              "FAILED",
              "SKIPPED"
            ]
          },
          "version": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "object",
                  "required": [
                    "source",
                    "locator"
                  ],
                  "properties": {
                    "source": {
                      "type": "string",
                      "minLength": 1
                    },
                    "locator": {
                      "type": "string",
                      "minLength": 1
                    },
                    "excerpt": {
                      "type": "string"
                    },
                    "tool": {
                      "type": "string"
                    },
                    "captured_at": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "PARTIAL",
        "DOC_ONLY",
        "UNVERIFIED",
        "CONFLICT"
      ]
    },
    "tool_status": {
      "type": "object",
      "required": [
        "normal_mode",
        "codegraph",
        "documentation"
      ],
      "properties": {
        "normal_mode": {
          "type": "boolean"
        },
        "codegraph": {
          "enum": [
            "READY",
            "PARTIAL",
            "BLOCKED"
          ]
        },
        "documentation": {
          "enum": [
            "AGENT_NATIVE",
            "OPENWIKI",
            "HYBRID",
            "BLOCKED"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "documentation_provider": {
      "enum": [
        "agent-native-docs",
        "openwiki-cli",
        "hybrid"
      ]
    },
    "codebases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/codebase"
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actor"
      }
    },
    "domains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "state_machines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachine"
      }
    },
    "business_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/businessRule"
      }
    },
    "domain_interactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domainInteraction"
      }
    },
    "business_streams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/businessStream"
      }
    },
    "visual_outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/visualOutput"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/uncertainty"
      }
    },
    "profile_support": {
      "type": "object",
      "required": [
        "default_profile",
        "supported_profiles",
        "default_workflows",
        "atlas_escalation_triggers"
      ],
      "properties": {
        "default_profile": {
          "const": "focus"
        },
        "supported_profiles": {
          "type": "array",
          "items": {
            "enum": [
              "focus",
              "atlas"
            ]
          },
          "uniqueItems": true,
          "contains": {
            "const": "focus"
          },
          "minContains": 1
        },
        "default_workflows": {
          "type": "array",
          "items": {
            "enum": [
              "orient",
              "trace",
              "explain",
              "before-change",
              "debug",
              "expand"
            ]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "atlas_escalation_triggers": {
          "type": "array",
          "items": {
            "enum": [
              "authentication",
              "authorization",
              "payment",
              "privacy",
              "data-deletion",
              "migration",
              "concurrency",
              "idempotency",
              "retry-compensation",
              "cross-repository",
              "conflicting-evidence",
              "dynamic-dispatch",
              "broad-state-change",
              "user-request"
            ]
          },
          "uniqueItems": true,
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
